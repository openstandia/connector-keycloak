<?xml version="1.0" encoding="UTF-8"?>
<scext:executeScript
  xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
  xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
  xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
  xmlns:scext="http://midpoint.evolveum.com/xml/ns/public/model/scripting/extension-3"
  xmlns:s="http://midpoint.evolveum.com/xml/ns/public/model/scripting-3"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <s:action>
        <s:type>execute-script</s:type>
        <s:parameter>
            <s:name>script</s:name>
            <c:value xsi:type="c:ScriptExpressionEvaluatorType">
                <c:code>
                    resourceOid = '150b94ef-9a4e-4092-8ba6-2a7fbbf4783c'

                    log.info('=== Testing Keycloak connector: oid={}', resourceOid)

                    result = midpoint.testResource(resourceOid)
                    status = result.getStatus()
                    log.info('=== Keycloak connector test result: {} (oid={})', status, resourceOid)

                    if (status.toString() != 'SUCCESS') {
                        log.error('=== Keycloak connector test FAILED: {}', result.getMessage())
                    }
                </c:code>
            </c:value>
        </s:parameter>
        <s:parameter>
            <s:name>forWholeInput</s:name>
            <c:value>true</c:value>
        </s:parameter>
    </s:action>
</scext:executeScript>
